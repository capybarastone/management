# URL of the Herd backend mTLS server (port 8443 by default)
BACKEND_URL=https://127.0.0.1:8443

# Path to the directory containing the operator cert/key and CA cert.
# The backend generates these on first run:
#   operator.crt  — client certificate presented during mTLS handshake
#   operator.key  — private key for the above
#   ca.crt        — CA used to verify the server certificate
BACKEND_CERTS_DIR=/home/matt/capstone/backend/certs

# Directory for management data (users.json, sessions.json)
MANAGEMENT_DATA_DIR=/home/matt/capstone/management/data
